{
  "SecurityGroups": [
    {
      "GroupId": "sg-001a",
      "GroupName": "prod-web-sg",
      "Description": "Production web server security group",
      "VpcId": "vpc-12345",
      "InboundRules": [
        {
          "Protocol": "TCP",
          "FromPort": 443,
          "ToPort": 443,
          "Source": "0.0.0.0/0",
          "Description": "HTTPS from internet"
        },
        {
          "Protocol": "TCP",
          "FromPort": 80,
          "ToPort": 80,
          "Source": "0.0.0.0/0",
          "Description": "HTTP redirect"
        },
        {
          "Protocol": "TCP",
          "FromPort": 22,
          "ToPort": 22,
          "Source": "0.0.0.0/0",
          "Description": "SSH - CHANGED: now open to all internet"
        },
        {
          "Protocol": "TCP",
          "FromPort": 3389,
          "ToPort": 3389,
          "Source": "0.0.0.0/0",
          "Description": "RDP - ADDED: new rule for Windows access"
        },
        {
          "Protocol": "-1",
          "FromPort": 0,
          "ToPort": 65535,
          "Source": "10.0.0.0/8",
          "Description": "All traffic from internal - ADDED"
        }
      ],
      "OutboundRules": [
        {
          "Protocol": "-1",
          "FromPort": 0,
          "ToPort": 0,
          "Destination": "0.0.0.0/0",
          "Description": "All outbound"
        }
      ],
      "Tags": {
        "Environment": "production",
        "Team": "infrastructure",
        "CostCenter": "CC-002"
      }
    },
    {
      "GroupId": "sg-002b",
      "GroupName": "prod-db-sg",
      "Description": "Production database security group",
      "VpcId": "vpc-12345",
      "InboundRules": [
        {
          "Protocol": "TCP",
          "FromPort": 5432,
          "ToPort": 5432,
          "Source": "10.0.0.0/8",
          "Description": "PostgreSQL - CHANGED: expanded from /24 to /8 (entire RFC1918 block)"
        }
      ],
      "OutboundRules": [],
      "Tags": {
        "Environment": "production",
        "Team": "database"
      }
    }
  ],
  "NetworkACLs": [
    {
      "AclId": "acl-001",
      "VpcId": "vpc-12345",
      "Rules": [
        {"RuleNumber": 100, "Protocol": "TCP", "Action": "ALLOW", "CidrBlock": "0.0.0.0/0", "PortRange": {"From": 443, "To": 443}},
        {"RuleNumber": 110, "Protocol": "-1", "Action": "ALLOW", "CidrBlock": "0.0.0.0/0", "PortRange": {"From": 0, "To": 65535}},
        {"RuleNumber": 32767, "Protocol": "-1", "Action": "DENY", "CidrBlock": "0.0.0.0/0", "PortRange": {"From": 0, "To": 65535}}
      ]
    }
  ],
  "DNSSettings": {
    "PrimaryDNS": "8.8.8.8",
    "SecondaryDNS": "1.1.1.1",
    "SearchDomain": "internal.company.com"
  },
  "Logging": {
    "CloudTrailEnabled": false,
    "VPCFlowLogsEnabled": false,
    "LogRetentionDays": 7
  }
}
