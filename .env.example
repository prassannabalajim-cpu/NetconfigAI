# ─────────────────────────────────────────────
# AI Network Config Diff Reviewer — ENV Config
# ─────────────────────────────────────────────

# Application
APP_NAME="AI Network Config Diff Reviewer"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG=False

# FastAPI / Security
SECRET_KEY="yoursecretkeyherechangeinproductionminimum32characterslong!"
ALLOWED_ORIGINS='["http://localhost:3000","http://localhost:8000"]'
ALLOWED_HOSTS='["*"]'

# PostgreSQL
POSTGRES_USER=netconfig_user
POSTGRES_PASSWORD=NetConfig@Secure2024!
POSTGRES_DB=netconfig_diff_db
DATABASE_URL="postgresql+asyncpg://netconfig_user:NetConfig%40Secure2024%21@db:5432/netconfig_diff_db"

# Redis
REDIS_PASSWORD=RedisNetConfig2024!
REDIS_URL="redis://:RedisNetConfig2024!@redis:6379/0"
CELERY_BROKER_URL="redis://:RedisNetConfig2024!@redis:6379/1"
CELERY_RESULT_BACKEND="redis://:RedisNetConfig2024!@redis:6379/2"

# AI / LLM
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_TIMEOUT_SECONDS=25
OLLAMA_BASE_URL="http://ollama:11434"
OLLAMA_MODEL="llama3"
OLLAMA_NUM_GPU=0

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/auth/google/callback"
FRONTEND_URL="http://localhost:3000"
VITE_GOOGLE_CLIENT_ID=""

# Frontend
VITE_API_BASE_URL="http://localhost:8000"

# Storage
STORAGE_BACKEND="local"
LOCAL_STORAGE_PATH="/app/storage"

# Grafana
GRAFANA_PASSWORD=GrafanaAdmin2024!
